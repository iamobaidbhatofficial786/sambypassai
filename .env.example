# =========================================================================
# CHROME EXTENSION LICENSING SYSTEM — ENVIRONMENT VARIABLES
# Copy to Vercel project settings (vercel-api) and local .env for development
# =========================================================================

# --- Supabase Database ---
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- JWT signing (use JWT_SECRET for HS256, or RS256 key pair) ---
# Option A: HS256 (simplest — server-only verification)
JWT_SECRET="your-long-random-jwt-secret-min-32-chars"

# Option B: RS256 (required if extension client-side JWT verify in security.js must work)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# --- Admin license creation ---
ADMIN_SECRET="your-admin-secret-for-create-endpoint"

# --- Extension API key (sent as apikey header from extension) ---
PUBLIC_API_KEY="pk_lov_ext_your_public_api_key"

# --- Legacy alias (optional) ---
POWERKITS_API_KEY="pk_lov_ext_your_public_api_key"

# --- Upstream proxy (premium features) ---
UPSTREAM_API_BASE="https://lov.powerkits.net"

# --- Admin dashboard (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
